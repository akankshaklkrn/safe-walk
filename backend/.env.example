# ──────────────────────────────────────────────────────────────────────────────
# SafeWalk Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# Server port (optional — defaults to 3000)
PORT=3000

# ── Google Maps Platform ───────────────────────────────────────────────────────
# Required for real route data.
# Leave blank to automatically run in mock mode (see below).
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Mock / Fallback Mode (Milestone 8) ────────────────────────────────────────
#
# SAFEWALK_MOCK_MODE
#   true  → Always use static mock routes. No API calls made.
#            Use this for offline demos, testing, or when you have no API key.
#   false → Use real Google Maps API (default).
#   (omit) → Auto-detected: mock if GOOGLE_MAPS_API_KEY is missing, real otherwise.
#
SAFEWALK_MOCK_MODE=false

#
# SAFEWALK_DISABLE_FALLBACK
#   true  → If real API fails, throw the error (good for integration tests).
#   false → If real API fails, silently fall back to mock routes (default).
#
SAFEWALK_DISABLE_FALLBACK=false
